!evolve/reports
evolve/reports/*
!evolve/reports/.gitkeep

# Pipeline-evolve loop — runtime state + private infra + private skills.
# scripts/eval_pipeline.py and scripts/eval_pipeline_vision.py are TRACKED
# because eval_all.py and docs/ARCHITECTURE.md reference them publicly.
evolve-pipeline/
evolve-pipeline-vision/
scripts/pipeline-evolve-bootstrap.sh
scripts/pipeline-evolve-runner.sh
scripts/pipeline-evolve-vision-bootstrap.sh
scripts/pipeline-evolve-vision-runner.sh
.claude/skills/microsolder-pipeline-evolve/
.claude/skills/microsolder-pipeline-evolve-monitor/
.claude/skills/microsolder-pipeline-evolve-vision/

# Agent-evolve loop — runtime state + private infra + private skills.
# scripts/eval_diagnostic_agent.py and benchmark/agent_scenarios.jsonl are
# TRACKED (eval_all.py / docs / tests reference them); the rest stays local.
evolve-agent/
scripts/agent-evolve-bootstrap.sh
scripts/agent-evolve-runner.sh
scripts/agent_baseline_report.py
scripts/clean_memory_store.py
.claude/skills/microsolder-agent-evolve/

# --- Demo / offline fallback ---
# Vendored CDN assets pulled by `make pin-cdn` (D3, marked, DOMPurify).
# Regenerated on demand; not tracked.
web/vendor/*.js

# Demo video intro page — recorded once for the hackathon submission,
# not a runtime route. Kept out of history; regenerate locally as needed.
web/intro.html
web/assets/

# Bench-generator per-run artefacts (auto_proposals_*) — research output of
# scripts/generate_bench_from_pack.py. The frozen oracle lives in
# benchmark/scenarios.jsonl; per-run dumps are local-only.
benchmark/auto_proposals/
benchmark/auto_proposals_*/
benchmark/poc_multi_agent/

