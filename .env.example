# Copy this file to `.env` and fill in the values below.
# `.env` is git-ignored — never commit real API keys.

# --- Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-xxx

# Main reasoning model (agent loop, tool planning).
ANTHROPIC_MODEL_MAIN=claude-opus-4-7

# Fast model for validation / formatting / cheap classification.
ANTHROPIC_MODEL_FAST=claude-haiku-4-5

# --- Server ---
PORT=8000
LOG_LEVEL=INFO

# --- Boardview cipher keys (optional — only needed for proprietary formats) ---
# These are runtime-configurable so the public repository ships only the
# parsing algorithm, never the keys themselves. Aligns with how
# OpenBoardView handles the same formats.
#
# FZ-xor cipher key (44 × uint32 expanded key, 176 bytes hex). Required
# only for .fz files that wrap the FZ-zlib container in the XOR stream
# cipher; plain FZ-zlib files parse without it.
WRENCH_BOARD_FZ_KEY=

# XZZ DES master key (8 bytes hex). Required for .pcb (XinZhiZao) files.
WRENCH_BOARD_XZZ_KEY=
